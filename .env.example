# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.prod
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Database
DATABASE_URL=postgres://esms:esms_password@db:5432/esms_db
POSTGRES_DB=esms_db
POSTGRES_USER=esms
POSTGRES_PASSWORD=esms_password
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://:redis_password@redis:6379/0
REDIS_PASSWORD=redis_password
CELERY_BROKER_URL=redis://:redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@redis:6379/1

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET_NAME=esms-media
AWS_ACCESS_KEY_ID=minio_access_key
AWS_SECRET_ACCESS_KEY=minio_secret_key
AWS_STORAGE_BUCKET_NAME=esms-media
AWS_S3_ENDPOINT_URL=http://minio:9000
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage

# JWT
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=1

# Frontend (used at build time)
VITE_API_URL=/api/v1

# Sentry (optional)
# SENTRY_DSN=https://your-dsn@sentry.io/your-project

# Logging
DJANGO_LOG_LEVEL=INFO
